{
  "name": "gooproxy",
  "scripts": {
    "test": "jest",
    "build:frontend": "esbuild src/frontend/assistant-ui-app.tsx --bundle --format=esm --target=es2022 --jsx=automatic --outfile=public/assistant-ui-app.js",
    "dev": "npm run build:frontend && wrangler dev",
    "deploy": "npm run build:frontend && WRANGLER_WRITE_LOGS=false WRANGLER_LOG=debug wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.14",
    "@hono/zod-validator": "^0.8.0",
    "@types/marked": "^5.0.2",
    "hono": "^4.12.23",
    "lucide-react": "^1.17.0",
    "marked": "^15.0.12",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260531.1",
    "@readme/openapi-parser": "^3.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "openapi-types": "^12.1.3",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "wrangler": "^4.95.0",
    "yaml": "^2.9.0"
  },
  "jest": {
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json",
      "node"
    ],
    "testEnvironment": "node"
  }
}
